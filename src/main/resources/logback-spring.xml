<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Color scheme per level:
        TRACE  → white/dim
        DEBUG  → cyan
        INFO   → green
        WARN   → yellow (bold)
        ERROR  → red (bold)
    -->

    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

    <!-- Level color helper: maps each level to an ANSI color -->
    <property name="LEVEL_COLOR_PATTERN"
              value="%clr(%5p){TRACE=white, DEBUG=cyan, INFO=green, WARN=yellow, ERROR=red}"/>

    <property name="CONSOLE_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr([%15.15t]){magenta} ${LEVEL_COLOR_PATTERN} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Per-package log levels -->
    <logger name="com.codewithsam.prsense" level="DEBUG"/>
    <logger name="org.springframework.web"  level="INFO"/>
    <logger name="org.hibernate.SQL"        level="WARN"/>
    <logger name="org.flywaydb"             level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
